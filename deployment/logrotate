# Logrotate config for cryptonote-nodejs-pool
#
# Update path and user:group below to match your setup
# 
# Install: sudo cp logrotate /etc/logrotate.d/cryptonote-pool
# Test:    sudo logrotate -d /etc/logrotate.d/cryptonote-pool
# Run:     sudo logrotate -f /etc/logrotate.d/cryptonote-pool
#


/home/ccxbeelink/cryptonote-nodejs-pool/logs/*.log {
    daily
    rotate 7
    missingok
    notifempty
    compress
    delaycompress
    maxsize 100M
    su ccxbeelink ccxbeelink
    create 0644 ccxbeelink ccxbeelink
    dateext
    dateformat -%Y%m%d
    nomail
    sharedscripts
}